{
  "name": "@cenk1cenk2/renovate-config",
  "version": "2.3.148",
  "description": "Renovate configuration generator for repositories.",
  "author": "Cenk Kilic",
  "license": "GPL-3.0-or-later",
  "repository": "https://gitlab.kilic.dev/renovate/renovate-config",
  "type": "module",
  "bin": {
    "renovate-config-generator": "./bin/run.js"
  },
  "files": [
    "/config",
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "scripts": {
    "dev": "./bin/dev.js",
    "start": "./bin/run.js",
    "build": "tsup-node",
    "dev:start": "tsup-node --watch",
    "format": "prettier --log-level warn --write ./ && eslint --fix ./src",
    "lint": "eslint ./src",
    "manifest": "oclif manifest"
  },
  "simple-git-hooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "./*.{ts,js,tsx,jsx}": [
      "prettier --log-level warn --write",
      "eslint --fix"
    ],
    "./*.{json,md}": [
      "prettier --log-level warn --write"
    ]
  },
  "oclif": {
    "bin": "renovate-config-generator",
    "dirname": "renovate-config-generator",
    "commands": "./dist/commands",
    "plugins": [],
    "hooks": {},
    "topicSeparator": " ",
    "default": "run"
  },
  "dependencies": {
    "@cenk1cenk2/oclif-common": "^6.3.29",
    "@listr2/manager": "^2.0.13",
    "@oclif/core": "^4.2.8",
    "fs-extra": "^11.3.0",
    "listr2": "^8.2.5",
    "renovate": "^39.185.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@cenk1cenk2/cz-cc": "^1.8.0",
    "@cenk1cenk2/eslint-config": "^3.1.29",
    "@swc/core": "^1.11.8",
    "@types/config": "^3.3.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "eslint": "9.22.0",
    "execa": "^9.5.2",
    "globby": "^14.1.0",
    "lint-staged": "^15.4.3",
    "oclif": "^4.17.34",
    "prettier": "^3.5.3",
    "simple-git-hooks": "^2.11.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-replace-paths": "^0.0.14",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@cenk1cenk2/cz-cc"
    }
  },
  "packageManager": "pnpm@9.15.7+sha512.ed98f9c748442673c46964b70345bd2282c9b305e8eae539b34ab31d6ef24ef8dd59d8b55f27466f705500b009d9c113471cf87e544f3d5036b297330c26e996"
}
