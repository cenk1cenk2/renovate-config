{
  "name": "@cenk1cenk2/renovate-config",
  "version": "2.3.148",
  "description": "Renovate configuration generator for repositories.",
  "author": "Cenk Kilic",
  "license": "GPL-3.0-or-later",
  "repository": "https://gitlab.kilic.dev/renovate/renovate-config",
  "type": "module",
  "bin": {
    "renovate-config-generator": "./bin/run.js"
  },
  "files": [
    "/config",
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "scripts": {
    "dev": "./bin/dev.js",
    "start": "./bin/run.js",
    "build": "tsdown src/",
    "dev:start": "tsdown --watch src/",
    "format": "prettier --log-level warn --write ./ && eslint --fix ./src",
    "lint": "eslint ./src",
    "manifest": "oclif manifest"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "./*.{ts,js,tsx,jsx}": [
      "prettier --log-level warn --write",
      "eslint --fix"
    ],
    "./*.{json,md}": [
      "prettier --log-level warn --write"
    ]
  },
  "oclif": {
    "bin": "renovate-config-generator",
    "dirname": "renovate-config-generator",
    "commands": "./dist/commands",
    "plugins": [],
    "hooks": {},
    "topicSeparator": " ",
    "default": "run"
  },
  "dependencies": {
    "@cenk1cenk2/oclif-common": "^6.4.5",
    "@listr2/manager": "^3.0.1",
    "@oclif/core": "^4.5.2",
    "@oxc-project/runtime": "^0.81.0",
    "fs-extra": "^11.3.1",
    "listr2": "^9.0.1",
    "renovate": "^41.58.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@cenk1cenk2/cz-cc": "^2.1.1",
    "@cenk1cenk2/eslint-config": "^3.1.61",
    "@types/config": "^3.3.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.2.1",
    "eslint": "9.33.0",
    "execa": "^9.6.0",
    "globby": "^14.1.0",
    "lint-staged": "^16.1.5",
    "oclif": "^4.22.6",
    "prettier": "^3.6.2",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsdown": "^0.13.4",
    "typescript": "^5.9.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@cenk1cenk2/cz-cc"
    }
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
