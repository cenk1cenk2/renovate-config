{
  "default": {
    "enabledManagers": [
      "ansible-galaxy",
      "argocd",
      "dockerfile",
      "gitlabci",
      "gitlabci-include",
      "gomod",
      "helmv3",
      "helm-values",
      "kubernetes",
      "kustomize",
      "npm",
      "ocb",
      "pep621",
      "custom.regex",
      "cargo",
      "terraform"
    ],
    "extends": [
      "local>renovate/renovate-config:default/base",
      "local>renovate/renovate-config:default/lock-file",
      "local>renovate/renovate-config:default/no-tests",
      "local>renovate/renovate-config:default/manager-ansible-galaxy",
      "local>renovate/renovate-config:default/manager-argocd",
      "local>renovate/renovate-config:default/manager-dockerfile",
      "local>renovate/renovate-config:default/manager-gitlab-ci",
      "local>renovate/renovate-config:default/manager-go",
      "local>renovate/renovate-config:default/manager-helm",
      "local>renovate/renovate-config:default/manager-kubernetes",
      "local>renovate/renovate-config:default/manager-kustomize",
      "local>renovate/renovate-config:default/manager-node",
      "local>renovate/renovate-config:default/manager-otel-builder",
      "local>renovate/renovate-config:default/manager-python",
      "local>renovate/renovate-config:default/manager-rust",
      "local>renovate/renovate-config:default/manager-terraform",
      "local>renovate/renovate-config:default/datasource-docker"
    ]
  },
  "base": {
    "extends": ["config:recommended", ":configMigration", ":dependencyDashboard", ":disableRateLimiting", ":updateNotScheduled", ":enableVulnerabilityAlerts"],
    "timezone": "Europe/Vienna",
    "semanticCommits": "enabled",
    "reviewers": ["cenk1cenk2"],
    "labels": ["renovate"],
    "prCreation": "immediate"
  },
  "lock-file": {
    "lockFileMaintenance": {
      "enabled": true,
      "automerge": true,
      "commitMessageSuffix": "[skip ci]",
      "labels": ["renovate", "lock"],
      "schedule": ["before 1am"]
    }
  },
  "no-tests": {
    "ignoreTests": true
  },
  "branch-develop": {
    "baseBranchPatterns": ["develop"]
  },
  "branch-beta": {
    "baseBranchPatterns": ["beta"]
  },
  "manager-node": {
    "enabledManagers": ["npm"],
    "extends": [
      "local>renovate/renovate-config:default/ring-node-none",
      "local>renovate/renovate-config:default/ring-node-slow",
      "local>renovate/renovate-config:default/ring-node-fast",
      "local>renovate/renovate-config:default/group-node-dev-dependencies",
      "local>renovate/renovate-config:default/group-node-minor-dependencies",
      "local>renovate/renovate-config:default/group-node-peer-dependencies"
    ],
    "packageRules": [
      {
        "matchManagers": ["npm"],
        "addLabels": ["node"]
      }
    ]
  },
  "manager-go": {
    "enabledManagers": ["gomod"],
    "extends": [
      "local>renovate/renovate-config:default/ring-go-slow",
      "local>renovate/renovate-config:default/ring-go-fast",
      "local>renovate/renovate-config:default/group-go-minor-dependencies"
    ],
    "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
    "packageRules": [
      {
        "matchManagers": ["gomod"],
        "addLabels": ["go"]
      }
    ]
  },
  "manager-python": {
    "enabledManagers": ["pep621"],
    "packageRules": [
      {
        "matchManagers": ["pep621"],
        "addLabels": ["python"]
      }
    ]
  },
  "manager-rust": {
    "enabledManagers": ["cargo"],
    "packageRules": [
      {
        "matchManagers": ["cargo"],
        "addLabels": ["rust"]
      }
    ]
  },
  "manager-kubernetes": {
    "enabledManagers": ["kubernetes"],
    "kubernetes": {
      "managerFilePatterns": [
        "/\\.deploy\\/.*\\/.*\\.ya?ml/",
        "/!(^\\.deploy\\/.*\\/kustomization\\.ya?ml$)/",
        "/!(^\\.deploy\\/.*\\/templates\\/)/",
        "/!(^\\.deploy\\/.*\\/files\\/)/",
        "/!(^\\.deploy\\/.*\\/values\\/)/",
        "/!(^\\.deploy\\/.*\\/values\\.ya?ml$)/",
        "/!(^\\.deploy\\/.*\\/chart\\.ya?ml$)/"
      ]
    },
    "packageRules": [
      {
        "matchManagers": ["kubernetes"],
        "addLabels": ["kubernetes"]
      }
    ]
  },
  "manager-kustomize": {
    "enabledManagers": ["kustomize"],
    "extends": ["local>renovate/renovate-config:default/group-kustomize-minor-helm-releases", "local>renovate/renovate-config:default/group-kustomize-major"],
    "schedule": ["at any time"],
    "packageRules": [
      {
        "matchManagers": ["kustomize"],
        "addLabels": ["kustomize"]
      }
    ]
  },
  "manager-helm": {
    "enabledManagers": ["helmv3", "helm-values"],
    "postUpdateOptions": ["helmUpdateSubChartArchives"],
    "extends": ["local>renovate/renovate-config:default/group-helm-minor", "local>renovate/renovate-config:default/group-helm-major"],
    "schedule": ["at any time"],
    "packageRules": [
      {
        "matchManagers": ["helmv3", "helm-values"],
        "addLabels": ["helm"]
      }
    ]
  },
  "manager-terraform": {
    "enabledManagers": ["terraform", "custom.regex"],
    "extends": [
      "local>renovate/renovate-config:default/manager-terraform-custom",
      "local>renovate/renovate-config:default/group-terraform-minor-helm-releases",
      "local>renovate/renovate-config:default/group-terraform-minor-providers",
      "local>renovate/renovate-config:default/group-terraform-minor-modules",
      "local>renovate/renovate-config:default/group-terraform-major"
    ],
    "schedule": ["at any time"],
    "packageRules": [
      {
        "matchManagers": ["terraform"],
        "addLabels": ["terraform"]
      },
      {
        "matchManagers": ["custom.regex"],
        "matchDepTypes": ["terraform-manager-git-monorepo"],
        "addLabels": ["terraform"]
      }
    ]
  },
  "manager-terraform-custom": {
    "customManagers": [
      {
        "depTypeTemplate": "terraform-manager-git-monorepo",
        "customType": "regex",
        "managerFilePatterns": ["/\\.tf$/"],
        "matchStringsStrategy": "any",
        "matchStrings": ["\"git::git@(?<registryUrl>[^:]+):(?<packageName>[^.]+)(\\.git)?\\/\\/.*\\?ref=(?<depName>.+)@(?<currentValue>[^\"]+)\""],
        "extractVersionTemplate": "^{{{depName}}}@(?<version>.*)$",
        "registryUrlTemplate": "https://{{{registryUrl}}}",
        "datasourceTemplate": "gitlab-tags",
        "versioningTemplate": "semver"
      }
    ]
  },
  "manager-ansible-galaxy": {
    "enabledManagers": ["ansible-galaxy"],
    "extends": ["local>renovate/renovate-config:default/group-ansible-galaxy-minor-roles"],
    "packageRules": [
      {
        "matchManagers": ["ansible-galaxy"],
        "addLabels": ["ansible"]
      }
    ]
  },
  "manager-dockerfile": {
    "enabledManagers": ["dockerfile"],
    "packageRules": [
      {
        "matchManagers": ["dockerfile"],
        "addLabels": ["dockerfile"]
      }
    ]
  },
  "manager-gitlab-ci": {
    "enabledManagers": ["gitlabci-include", "gitlabci", "custom.regex"],
    "extends": ["local>renovate/renovate-config:default/manager-gitlab-ci-custom", "local>renovate/renovate-config:default/group-gitlab-ci-minor-updates"],
    "packageRules": [
      {
        "matchManagers": ["gitlabci-include", "gitlabci"],
        "addLabels": ["gitlab-ci"]
      },
      {
        "matchManagers": ["custom.regex"],
        "matchDepTypes": ["gitlab-ci-manager-git-monorepo"],
        "addLabels": ["gitlab-ci"]
      }
    ]
  },
  "manager-gitlab-ci-custom": {
    "customManagers": [
      {
        "depTypeTemplate": "gitlab-ci-manager-git-monorepo",
        "customType": "regex",
        "managerFilePatterns": ["/\\.gitlab-ci\\.ya?ml$/", "/\\.gitlab-ci\\..*\\.ya?ml$/"],
        "matchStringsStrategy": "any",
        "matchStrings": ["project:\\s+['\"]?(?<packageName>[^'\"\\s]+)['\"]?\\s*ref:\\s+['\"]?(?<depName>[^@]+)@(?<currentValue>[^'\"\\s]+)['\"]?"],
        "registryUrlTemplate": "https://gitlab.kilic.dev/",
        "extractVersionTemplate": "^{{{depName}}}@(?<version>.*)$",
        "datasourceTemplate": "gitlab-tags",
        "versioningTemplate": "semver"
      }
    ]
  },
  "manager-otel-builder": {
    "enabledManagers": ["ocb"],
    "packageRules": [
      {
        "matchPackageNames": ["*"],
        "groupName": "otel-builder all minor dependency updates",
        "groupSlug": "otel-builder-minor",
        "matchUpdateTypes": ["minor", "patch", "digest"],
        "labels": ["renovate", "minor", "automerge"],
        "automerge": true,
        "matchManagers": ["ocb"],
        "schedule": ["before 1am"]
      },
      {
        "matchManagers": ["ocb"],
        "addLabels": ["otel-builder"]
      }
    ]
  },
  "manager-argocd": {
    "enabledManagers": ["argocd"],
    "extends": ["local>renovate/renovate-config:default/group-argocd-minor", "local>renovate/renovate-config:default/group-argocd-major"],
    "schedule": ["at any time"],
    "packageRules": [
      {
        "matchManagers": ["argocd"],
        "addLabels": ["argocd"]
      }
    ]
  },
  "datasource-docker": {
    "packageRules": [
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
        "labels": ["renovate", "minor", "infrastructure", "automerge"],
        "groupName": "docker datasource minor dependency updates",
        "groupSlug": "docker-minor",
        "automerge": true,
        "matchDatasources": ["docker"],
        "matchPackageNames": ["ghcr.io/open-telemetry/opentelemetry-collector-releases/opentelemetry-collector-contrib", "renovate/renovate"],
        "schedule": ["at any time"]
      }
    ]
  },
  "group-node-minor-dependencies": {
    "packageRules": [
      {
        "matchPackageNames": ["*"],
        "groupName": "node all minor dependency updates",
        "groupSlug": "node-minor",
        "matchDepTypes": ["dependencies"],
        "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
        "labels": ["renovate", "minor", "automerge"],
        "automerge": true,
        "matchManagers": ["npm"],
        "schedule": ["before 1am"]
      },
      {
        "matchManagers": ["npm"],
        "matchDepTypes": ["dependencies"],
        "rangeStrategy": "bump"
      }
    ]
  },
  "group-node-dev-dependencies": {
    "packageRules": [
      {
        "matchPackageNames": ["*"],
        "groupName": "node all development dependency updates",
        "groupSlug": "node-dev",
        "matchDepTypes": ["devDependencies"],
        "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
        "commitMessageSuffix": "[skip ci]",
        "labels": ["renovate", "dev-deps", "automerge"],
        "automerge": true,
        "matchManagers": ["npm"],
        "schedule": ["at any time"]
      },
      {
        "matchPackageNames": [
          "typescript",
          "tsup",
          "tsdown",
          "prettier",
          "eslint",
          "@cenk1cenk2/eslint-config",
          "@swc/core",
          "@types/jest",
          "jest",
          "ts-jest",
          "/^eslint-plugin-/",
          "/^jest/"
        ],
        "groupName": "node all build dependency updates",
        "groupSlug": "node-build",
        "matchDepTypes": ["devDependencies"],
        "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
        "semanticCommitType": "build",
        "commitMessageSuffix": "",
        "labels": ["renovate", "build-deps", "automerge"],
        "automerge": true,
        "matchManagers": ["npm"],
        "schedule": ["at any time"]
      },
      {
        "matchPackageNames": ["typedoc", "typedoc-plugin-markdown", "/^vitepress/", "/^markdown-it/"],
        "groupName": "node all docs dependency updates",
        "groupSlug": "node-docs",
        "matchDepTypes": ["devDependencies"],
        "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
        "semanticCommitType": "docs",
        "commitMessageSuffix": "",
        "labels": ["renovate", "build-deps", "automerge"],
        "automerge": true,
        "matchManagers": ["npm"],
        "schedule": ["at any time"]
      },
      {
        "groupName": "node all package manager",
        "groupSlug": "node-package-manager",
        "matchManagers": ["npm"],
        "rangeStrategy": "widen",
        "matchDepNames": ["pnpm", "yarn", "npm", "bun"],
        "labels": ["renovate", "engines", "automerge"],
        "commitMessageSuffix": "[skip ci]",
        "automerge": true,
        "schedule": ["at any time"]
      },
      {
        "matchManagers": ["npm"],
        "matchDepTypes": ["devDependencies"],
        "rangeStrategy": "bump"
      }
    ]
  },
  "group-node-peer-dependencies": {
    "packageRules": [
      {
        "matchPackageNames": ["*"],
        "groupName": "node all peer dependency updates",
        "groupSlug": "node-peer",
        "enabled": false,
        "matchDepTypes": ["peerDependencies", "optionalDependencies"],
        "rangeStrategy": "widen",
        "commitMessageSuffix": "[skip ci]",
        "labels": ["renovate", "peer-deps", "automerge"],
        "automerge": true,
        "matchManagers": ["npm"],
        "schedule": ["at any time"]
      }
    ]
  },
  "group-go-minor-dependencies": {
    "packageRules": [
      {
        "matchPackageNames": ["*"],
        "groupName": "go all minor dependency updates",
        "groupSlug": "go-minor",
        "matchUpdateTypes": ["minor", "patch", "digest"],
        "labels": ["renovate", "minor", "automerge"],
        "automerge": true,
        "matchManagers": ["gomod"],
        "schedule": ["before 1am"]
      }
    ]
  },
  "group-kustomize-minor-helm-releases": {
    "packageRules": [
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch"],
        "labels": ["renovate", "minor", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "kustomize all minor dependency updates",
        "groupSlug": "kustomize-minor",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(feat)"],
        "matchDepTypes": ["HelmChart"],
        "matchManagers": ["kustomize"]
      },
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch"],
        "labels": ["renovate", "minor", "infrastructure", "automerge"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "kustomize all minor automerge dependency updates",
        "groupSlug": "kustomize-minor-automerge",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": true,
        "extends": [":semanticCommitTypeAll(feat)"],
        "matchDepTypes": ["HelmChart"],
        "matchManagers": ["kustomize"],
        "matchSourceUrls": ["https://github.com/prometheus-community/helm-charts", "https://github.com/grafana/helm-charts"],
        "matchPackageNames": ["prometheus-blackbox-exporter", "alloy"]
      }
    ]
  },
  "group-kustomize-major": {
    "packageRules": [
      {
        "enabled": true,
        "matchUpdateTypes": ["major"],
        "labels": ["renovate", "major", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "kustomize all major dependency updates",
        "groupSlug": "kustomize-major",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(perf)"],
        "matchDepTypes": ["HelmChart"],
        "matchManagers": ["kustomize"]
      },
      {
        "enabled": true,
        "matchUpdateTypes": ["major"],
        "labels": ["renovate", "major", "infrastructure", "automerge"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "kustomize all major automerge dependency updates",
        "groupSlug": "kustomize-major-automerge",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": true,
        "extends": [":semanticCommitTypeAll(perf)"],
        "matchDepTypes": ["HelmChart"],
        "matchManagers": ["kustomize"],
        "matchSourceUrls": ["https://github.com/prometheus-community/helm-charts", "https://github.com/grafana/helm-charts"],
        "matchPackageNames": ["prometheus-blackbox-exporter", "alloy"]
      }
    ]
  },
  "group-helm-minor": {
    "packageRules": [
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch"],
        "labels": ["renovate", "minor", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "helm all minor dependency updates",
        "groupSlug": "helm-minor",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(feat)"],
        "matchManagers": ["helmv3"]
      },
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch"],
        "labels": ["renovate", "minor", "infrastructure", "automerge"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "helm all minor automerge dependency updates",
        "groupSlug": "helm-minor-automerge",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": true,
        "extends": [":semanticCommitTypeAll(feat)"],
        "matchManagers": ["helmv3"],
        "matchSourceUrls": ["https://github.com/prometheus-community/helm-charts", "https://github.com/open-telemetry/opentelemetry-helm-charts"],
        "matchPackageNames": ["kube-prometheus-stack", "blackbox-exporter", "opentelemetry-operator"]
      }
    ]
  },
  "group-helm-major": {
    "packageRules": [
      {
        "enabled": true,
        "matchUpdateTypes": ["major"],
        "labels": ["renovate", "major", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "helm all major dependency updates",
        "groupSlug": "helm-major",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(perf)"],
        "matchManagers": ["helmv3"]
      },
      {
        "enabled": true,
        "matchUpdateTypes": ["major"],
        "labels": ["renovate", "major", "infrastructure", "automerge"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "helm all major automerge dependency updates",
        "groupSlug": "helm-major-automerge",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": true,
        "extends": [":semanticCommitTypeAll(perf)"],
        "matchManagers": ["helmv3"],
        "matchSourceUrls": ["https://github.com/prometheus-community/helm-charts", "https://github.com/open-telemetry/opentelemetry-helm-charts"],
        "matchPackageNames": ["kube-prometheus-stack", "blackbox-exporter", "opentelemetry-operator"]
      }
    ]
  },
  "group-terraform-minor-helm-releases": {
    "packageRules": [
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch"],
        "labels": ["renovate", "minor", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "terraform all minor dependency updates",
        "groupSlug": "terraform-minor",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(feat)"],
        "matchDepTypes": ["helm_release"],
        "matchManagers": ["terraform"]
      }
    ]
  },
  "group-terraform-minor-modules": {
    "packageRules": [
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch"],
        "labels": ["renovate", "minor", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "terraform all minor dependency updates",
        "groupSlug": "terraform-minor",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(feat)"],
        "matchDepTypes": ["module"],
        "matchManagers": ["terraform"]
      },
      {
        "enabled": false,
        "matchDepTypes": ["module"],
        "matchManagers": ["terraform"],
        "matchSourceUrls": ["https://gitlab.kilic.dev/**"]
      },
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch"],
        "labels": ["renovate", "minor", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "terraform-monorepo all minor dependency updates",
        "groupSlug": "terraform-monorepo-minor",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(feat)"],
        "matchDepTypes": ["terraform-manager-git-monorepo"],
        "matchManagers": ["custom.regex"],
        "matchSourceUrls": ["https://gitlab.kilic.dev/**"]
      }
    ]
  },
  "group-terraform-minor-providers": {
    "packageRules": [
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch"],
        "labels": ["renovate", "minor", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "terraform all minor dependency updates",
        "groupSlug": "terraform-minor",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(feat)"],
        "matchDepTypes": ["provider"],
        "matchManagers": ["terraform"]
      },
      {
        "enabled": true,
        "matchUpdateTypes": ["minor", "patch"],
        "labels": ["renovate", "minor", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "terraform all minor dependency updates",
        "groupSlug": "terraform-minor",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(feat)"],
        "matchDepTypes": ["required_provider"],
        "matchManagers": ["terraform"]
      },
      {
        "matchManagers": ["terraform"],
        "matchDepTypes": ["required_provider"],
        "rangeStrategy": "replace"
      }
    ]
  },
  "group-terraform-major": {
    "packageRules": [
      {
        "enabled": true,
        "matchUpdateTypes": ["major"],
        "labels": ["renovate", "major", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "terraform all major dependency updates",
        "groupSlug": "terraform-major",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(perf)"],
        "matchDepTypes": ["helm_release", "provider", "required_provider", "module"],
        "matchManagers": ["terraform"]
      },
      {
        "enabled": true,
        "matchUpdateTypes": ["major"],
        "labels": ["renovate", "major", "infrastructure"],
        "additionalBranchPrefix": "{{packageFileDir}}-",
        "groupName": "terraform-monorepo all major dependency updates",
        "groupSlug": "terraform-monorepo-major",
        "commitMessageExtra": "to {{{newValue}}} [{{packageFileDir}}]",
        "automerge": false,
        "extends": [":semanticCommitTypeAll(perf)"],
        "matchDepTypes": ["terraform-manager-git-monorepo"],
        "matchManagers": ["custom.regex"],
        "matchSourceUrls": ["https://gitlab.kilic.dev/**"]
      }
    ]
  },
  "group-ansible-galaxy-minor-roles": {
    "packageRules": [
